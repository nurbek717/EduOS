{
  "name": "school-management-backend",
  "version": "1.0.0",
  "description": "Multi-school SaaS school management backend (Node.js, Express, MongoDB, JWT)",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "NODE_ENV=production node src/server.js",
    "seed:demo": "node src/config/seed-demo.js",
    "seed:saas-plans": "node src/config/seed-saas-plans.js",
    "backfill:school-days": "node src/scripts/backfill-school-created-day.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:all": "npm --prefix .. run test && npm test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.4",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2"
  }
}
